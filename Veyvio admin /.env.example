# Frontend-only demo mode (default) — no veymo API needed
VITE_MOCK_API=true

# Set to false and configure API URL to connect to veymo backend:
# VITE_MOCK_API=false
# VITE_API_URL=http://localhost:4000

# Optional MapLibre tile style
# VITE_MAP_TILE_STYLE=https://tiles.openfreemap.org/styles/liberty
