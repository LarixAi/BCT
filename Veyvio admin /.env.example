# Frontend-only demo mode (default) — no Veyvio API needed
VITE_MOCK_API=true

# Set to false and configure the Supabase Edge Function REST gateway:
# VITE_MOCK_API=false
# Local Supabase:
# VITE_API_URL=http://127.0.0.1:54321/functions/v1/command-api
# VITE_SUPABASE_ANON_KEY=your-local-anon-key
#
# Hosted project (qeckgqjrfbdyxchuncdt):
# VITE_API_URL=https://qeckgqjrfbdyxchuncdt.supabase.co/functions/v1/command-api
# VITE_SUPABASE_ANON_KEY=your-project-anon-key
#
# Find the anon key in Supabase → Project Settings → API.
# Never commit service_role keys.

# Supabase personal access token (Dashboard → Account → Access Tokens).
# Used for Management API / `supabase` CLI locally — not a user session JWT.
# Never commit the real value; keep it only in gitignored `.env`.
# SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxx
# SUPABASE_PROJECT_REF=qeckgqjrfbdyxchuncdt

# Driver app origin for invitation links (Admin UI copy-link banner)
# VITE_DRIVER_APP_URL=http://localhost:8081
#
# Edge Function secrets (set via supabase secrets — never commit service role keys):
#   VEYVIO_DRIVER_APP_URL=http://192.168.1.136:8081
#   VEYVIO_ADMIN_APP_URL=http://localhost:5173
# Also add the Driver accept URL to Supabase Auth → Redirect URLs:
#   http://192.168.1.136:8081/accept-invitation
#   http://localhost:8081/accept-invitation

# Optional MapLibre tile style
# VITE_MAP_TILE_STYLE=https://tiles.openfreemap.org/styles/liberty
