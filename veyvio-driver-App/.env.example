# Supabase — copy from repo root .env.local
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Veyvio Command API (driver session + login) — required for invited Command drivers
VITE_COMMAND_API_BASE_URL=https://your-project.supabase.co/functions/v1/command-api
VITE_AUTH_API_BASE_URL=https://your-project.supabase.co/functions/v1/command-api

# Public URL for email confirmation / OAuth redirects (https://localhost on device APK)
VITE_DRIVER_APP_URL=https://localhost

# Supabase edge function secrets (set via CLI — NOT in this file):
#   GOOGLE_ROUTES_API_KEY       — Google Routes API key (server-side only)
#   GOOGLE_ROUTES_MONTHLY_LIMIT — default 9500 (Essentials free tier buffer)

# Navigation routing (driver app)
# Test/dev: OSRM only — never uses Google quota (safe for phone testing)
# VITE_DRIVER_NAV_TEST_MODE=true
# Production: Google Essentials via edge function (default when unset)
# VITE_DRIVER_NAV_USE_GOOGLE=true

# Phase 4: Google Roads correction loop (off by default — adds Roads API SKU)
# VITE_NAV_USE_GOOGLE_ROADS=true

# Phase 7: Pure MapLibre GL JS Jobs map (replaces Leaflet on this screen)
# VITE_NAV_USE_MAPLIBRE=true

# Optional: layer OpenFreeMap vector on top of Carto raster (can blank on first open)
# VITE_DRIVER_MAP_GL=true

# Phase 0: Dev-only navigation diagnostics overlay on the Jobs map
# VITE_NAV_DEBUG=true

# Mobile push (FCM) — only set true after adding android/app/google-services.json and rebuilding
# VITE_ENABLE_PUSH=true

# Local dev: fleet admin server for auth when Supabase rate-limits sign-in (port 8080)
# VITE_FLEET_API_URL=http://localhost:8080
