{
  "name": "@veyvio/driver",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mobile": "DRIVER_MOBILE=true vite --open /",
    "build": "vite build",
    "build:android": "set -a && [ -f .env.local ] && . ./.env.local; set +a && vite build && npx cap sync android",
    "build:ios": "set -a && [ -f .env.local ] && . ./.env.local; set +a && vite build && npx cap sync ios",
    "android:apk": "cd android && JAVA_HOME=\"${JAVA_HOME:-$HOME/.jdks/jdk-21.0.11+10/Contents/Home}\" ./gradlew assembleDebug",
    "android:install": "adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "android:launch": "adb shell monkey -p com.coresupport.fleet.driver -c android.intent.category.LAUNCHER 1",
    "android:run": "npm run build:android && npm run android:apk && npm run android:install && npm run android:launch",
    "typecheck": "tsc -p ./jsconfig.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run src/lib/command-duty-nav-job.e2e.test.js"
  },
  "dependencies": {
