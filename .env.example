# Veyvio Yard — Environment

# Skip auth guard during local UI development (full app without sign-in flow)
# VITE_DEV_BYPASS_AUTH=true

# Used by Playwright e2e (see playwright.config.ts)
# VITE_E2E=true

# --- API (mock-first: no backend required for local dev) ---
# Default: mock API — fixtures + IndexedDB. App works fully offline.
# VITE_USE_MOCK_API=true

# When you have a real backend, set both:
# VITE_API_BASE_URL=https://api.example.com
# VITE_USE_MOCK_API=false

# Or use the built-in dev stub API (same Vite server):
# VITE_API_BASE_URL=http://localhost:8080/api
# VITE_USE_MOCK_API=false

# --- Supabase CLI / Management API (local only — copy to gitignored `.env`) ---
# Dashboard → Account → Access Tokens. Not a Command/Driver login JWT.
# SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxx
# SUPABASE_PROJECT_REF=qeckgqjrfbdyxchuncdt
