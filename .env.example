# Veyvio Yard — Environment

# Skip auth guard during local UI development (full app without sign-in flow)
# VITE_DEV_BYPASS_AUTH=true

# Used by Playwright e2e (see playwright.config.ts)
# VITE_E2E=true

# --- Auth / API (mock-first) ---
# Default: mock sign-in when Command URL + anon key are missing.
# VITE_USE_MOCK_AUTH=true

# Live Command backend (same as Admin) — copy from `Veyvio admin /.env`:
# VITE_USE_MOCK_AUTH=false
# VITE_API_URL=https://qeckgqjrfbdyxchuncdt.supabase.co/functions/v1/command-api
# VITE_SUPABASE_URL=https://qeckgqjrfbdyxchuncdt.supabase.co
# VITE_SUPABASE_ANON_KEY=your-project-anon-key
#
# Local Supabase Edge:
# VITE_API_URL=http://127.0.0.1:54321/functions/v1/command-api
# VITE_SUPABASE_ANON_KEY=your-local-anon-key

# Legacy yard stub (optional). Prefer Command URL above for live auth + /yard/hub.
# VITE_USE_MOCK_API=false
# VITE_API_BASE_URL=http://localhost:8080/api

# --- Supabase CLI / Management API (local only — copy to gitignored `.env`) ---
# Dashboard → Account → Access Tokens. Not a Command/Driver login JWT.
# SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxx
# SUPABASE_PROJECT_REF=qeckgqjrfbdyxchuncdt
