# Veyvio Driver — Environment

# Skip auth guard during local UI development (copy to .env.local)
VITE_DEV_BYPASS_AUTH=true

# Mock API (default) — fixtures + IndexedDB, no backend required
# VITE_USE_MOCK_API=true

# Real backend:
# VITE_API_BASE_URL=https://api.example.com
# VITE_USE_MOCK_API=false
