# Veyvio Driver — Environment

# Development-only settings (copy to .env.local).
# Both are explicit opt-ins and production builds reject either setting.
VITE_DEV_BYPASS_AUTH=true

# Mock API — fixtures + IndexedDB, no backend required
VITE_USE_MOCK_API=true

# Real backend:
# VITE_API_BASE_URL=https://api.example.com
# VITE_USE_MOCK_API=false
