{
  "name": "veyvio-driver",
  "private": true,
  "sideEffects": false,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:phone": "vite dev --host 0.0.0.0 --port 8081",
    "phone:url": "node scripts/phone-dev-url.mjs",
    "cap:live:android": "node scripts/phone-dev-url.mjs && CAPACITOR_SERVER_URL=http://$(ipconfig getifaddr en0 2>/dev/null || hostname -I | awk '{print $1}'):8081 npx cap run android",
    "build": "vite build",
    "build:mobile": "VITE_MOBILE_BUILD=true vite build --mode mobile",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "cap:sync": "npm run build:mobile && npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:build:apk": "npm run cap:sync && cd android && JAVA_HOME=\"$(pwd)/../.jdk/jdk-21.0.11+10/Contents/Home\" ./gradlew assembleDebug",
    "cap:install:phone": "adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "icons:android": "node scripts/generate-brand-icons.mjs"
  },
  "dependencies": {
    "@capacitor-community/keep-awake": "^7.1.0",
    "@capacitor-mlkit/barcode-scanning": "^8.1.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.2.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-start": "^1.168.26",
    "@tanstack/router-plugin": "^1.168.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.3.4",
    "zod": "^3.24.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@lovable.dev/vite-tanstack-config": "^2.7.1",
    "@playwright/test": "^1.55.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.16.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "nitro": "3.0.260603-beta",
    "sharp": "^0.35.3",
    "typescript": "^5.8.3",
    "vite": "^8.0.16",
    "vitest": "^3.2.7"
  }
}
